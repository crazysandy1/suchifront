# Production environment for Vercel deployment
# Set these in Vercel Dashboard: Project Settings → Environment Variables

# Backend API route (Vercel experimentalServices routing)
VITE_API_URL=/_/backend/api

# Polygon blockchain (optional)
VITE_POLYGON_NETWORK=polygon-amoy
VITE_POLYGON_CHAIN_ID=80002
VITE_CONTRACT_ADDRESS=0x_your_deployed_contract_address
