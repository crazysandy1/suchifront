# Backend API URL
# Local development: http://localhost:5000/api
# Vercel production: /_/backend/api (experimentalServices routing)
VITE_API_URL=http://localhost:5000/api

# Polygon (optional — for blockchain verification links in the UI)
# polygon-amoy = testnet (chainId 80002), polygon = mainnet (chainId 137)
VITE_POLYGON_NETWORK=polygon-amoy
VITE_POLYGON_CHAIN_ID=80002
VITE_CONTRACT_ADDRESS=0x_your_deployed_contract_address
